{
  "name": "activitylog-monorepo",
  "private": true,
  "description": "Monorepo for activitylog-core, activitylog-nestjs and activitylog-nextjs.",
  "license": "MIT",
  "workspaces": [
    "packages/core",
    "packages/activitylog-nestjs",
    "packages/activitylog-nextjs"
  ],
  "scripts": {
    "build": "npm run build -w activitylog-core && npm run build -w activitylog-nestjs && npm run build -w activitylog-nextjs && node scripts/verify-core-singleton.cjs",
    "prisma:test:generate": "node scripts/generate-prisma-test-clients.cjs",
    "pretypecheck": "npm run prisma:test:generate",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run prisma:test:generate",
    "test": "vitest run",
    "pretest:coverage": "npm run prisma:test:generate",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"test/**/*.ts\"",
    "smoke:nestjs": "node scripts/smoke-nestjs-consumer.cjs",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/testing": "^11.1.28",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "@vitest/coverage-v8": "^4.1.10",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "*",
    "eslint": "^8",
    "mysql2": "^3.22.6",
    "pg": "^8.22.0",
    "prisma": "7.8.0",
    "reflect-metadata": "^0.2",
    "tsup": "^8",
    "typeorm": "^0.3",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
