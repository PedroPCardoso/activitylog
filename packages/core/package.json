{
  "name": "activitylog-core",
  "version": "0.1.0",
  "description": "ORM-agnostic entity activity log core for TypeScript.",
  "keywords": [
    "activitylog",
    "audit",
    "audit-log",
    "entity-history",
    "typescript",
    "sql"
  ],
  "author": "Pedro Cardoso",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroPCardoso/activitylog.git",
    "directory": "packages/core"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  }
}
